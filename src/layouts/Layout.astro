---
import "../styles/global.css";
import { getLangFromUrl } from "../i18n/utils";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Valentín Kebat — Data Engineer especializado en pipelines de datos, arquitecturas cloud y analítica avanzada.",
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const canonicalURL = new URL(
	Astro.url.pathname,
	"https://valentinkebat.com.ar",
);
const ogImage = "https://valentinkebat.com.ar/valentin-kebat.jpg";

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Valentín Kebat",
	url: "https://valentinkebat.com.ar",
	image: ogImage,
	jobTitle: "Data Engineer",
	sameAs: [
		"https://www.linkedin.com/in/valentin-kebat/",
		"https://github.com/Valenkebat",
	],
	knowsAbout: [
		"Data Engineering",
		"Python",
		"SQL",
		"Apache Spark",
		"dbt",
		"Cloud Computing",
		"ETL Pipelines",
	],
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="canonical" href={canonicalURL} />

		<!-- SEO primario -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Valentín Kebat" />
		<meta
			name="keywords"
			content="Valentín Kebat, Valentin Kebat, Data Engineer, Python, SQL, dbt, Spark, portfolio, Argentina"
		/>
		<meta name="robots" content="index, follow" />

		<!-- Open Graph (LinkedIn, WhatsApp, Facebook) -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta
			property="og:locale"
			content={lang === "es" ? "es_AR" : "en_US"}
		/>
		<meta property="og:site_name" content="Valentín Kebat — Portfolio" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<!-- Cloudflare Web Analytics -->
		<script
			defer
			src="https://static.cloudflareinsights.com/beacon.min.js"
			data-cf-beacon='{"token": "68c152e92dba44579c24f38f9b41242d"}'
		></script>
		<!-- End Cloudflare Web Analytics -->

		<!-- Google Analytics -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-PD3J00VRY6"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-PD3J00VRY6');
		</script>
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
