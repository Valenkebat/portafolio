---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const experiences = {
  es: [
    {
      role: 'Data Engineer',
      company: 'Moni',
      period: 'Actualidad',
      type: 'current',
      bullets: [
        'Diseño y mantenimiento de pipelines de datos escalables con Python y SQL.',
        'Orquestación de flujos de trabajo con Apache Airflow.',
        'Gestión de infraestructura en AWS (Redshift, S3, ECS, Fargate).',
        'Implementación de modelos y transformaciones con dbt.',
      ],
      tags: ['Python', 'SQL', 'Apache Airflow', 'dbt', 'AWS', 'Redshift', 'S3'],
    },
    {
      role: 'Data Engineer & Analyst',
      company: 'Ministerio de Obras Públicas de la Nación',
      period: '2020 – 2024',
      type: 'past',
      bullets: [
        'Desarrollo de scripts Python para normalización de geodatos en shapefiles.',
        'Mantenimiento de datasets en SQL Server con PL/SQL y Python.',
        'Creación de tableros de control con Tableau.',
      ],
      tags: ['Python', 'SQL Server', 'PL/SQL', 'Tableau', 'GIS'],
    },
    {
      role: 'Operador de Datos SIG',
      company: 'Dirección Provincial de Estadística',
      period: 'Feb 2020 – Sept 2020',
      type: 'past',
      bullets: [
        'Gestión de carga de datos y actualización de cartografía mediante ArcGIS 10.2.',
      ],
      tags: ['ArcGIS', 'SIG', 'Cartografía'],
    },
  ],
  en: [
    {
      role: 'Data Engineer',
      company: 'Moni',
      period: 'Present',
      type: 'current',
      bullets: [
        'Designed, built, and maintained scalable data extraction and processing pipelines using Python and SQL.',
        'Orchestrated workflows and automated task scheduling using Apache Airflow.',
        'Managed AWS cloud infrastructure (Redshift, S3, ECS, Fargate).',
        'Implemented data modeling and transformation strategies utilizing dbt.',
      ],
      tags: ['Python', 'SQL', 'Apache Airflow', 'dbt', 'AWS', 'Redshift', 'S3'],
    },
    {
      role: 'Data Engineer & Analyst',
      company: 'National Ministry of Public Works',
      period: '2020 – 2024',
      type: 'past',
      bullets: [
        'Developed Python scripts for geodata normalization into shapefiles.',
        'Maintained large datasets in SQL Server using PL/SQL and Python.',
        'Built data visualization dashboards using Tableau.',
      ],
      tags: ['Python', 'SQL Server', 'PL/SQL', 'Tableau', 'GIS'],
    },
    {
      role: 'GIS Data Operator',
      company: 'Provincial Directorate of Statistics',
      period: 'Feb 2020 – Sept 2020',
      type: 'past',
      bullets: [
        'Managed data upload workflows and cartography updates using ArcGIS 10.2.',
      ],
      tags: ['ArcGIS', 'GIS', 'Cartography'],
    },
  ],
};

const items = experiences[lang];
---

<section class="experience-section" id="experience">
  <div class="container">
    <h2 class="section-title">{t('experience.title')}</h2>

    <div class="timeline">
      {items.map((exp, i) => (
        <div class={`timeline-item ${exp.type}`}>
          <div class="timeline-marker">
            <div class="dot"></div>
            {i < items.length - 1 && <div class="line"></div>}
          </div>
          <div class="timeline-card glass">
            <div class="card-header">
              <div>
                <h3 class="role">{exp.role}</h3>
                <p class="company">{exp.company}</p>
              </div>
              <span class={`period mono ${exp.type === 'current' ? 'period-current' : ''}`}>
                {exp.period}
              </span>
            </div>
            <ul class="bullets">
              {exp.bullets.map(b => (
                <li>{b}</li>
              ))}
            </ul>
            <div class="exp-tags">
              {exp.tags.map(tag => (
                <span class="exp-tag">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .experience-section {
    padding: 6rem 0;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 1.25rem;
  }

  .dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-border);
    border: 2px solid var(--color-border);
    flex-shrink: 0;
    transition: var(--transition);
  }

  .timeline-item.current .dot {
    background: var(--color-primary);
    border-color: var(--color-primary);
    box-shadow: 0 0 10px var(--color-primary-glow);
  }

  .line {
    width: 2px;
    flex: 1;
    background: var(--color-border);
    margin-top: 6px;
    min-height: 40px;
  }

  .timeline-card {
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    transition: var(--transition);
  }

  .timeline-card:hover {
    border-color: rgba(0, 255, 204, 0.2);
    transform: translateY(-2px);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .role {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.2rem;
  }

  .company {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .period {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    padding: 0.25rem 0.6rem;
    background: var(--color-surface-hover);
    border-radius: var(--radius-sm);
  }

  .period-current {
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
    background: var(--color-primary-glow);
  }

  .bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .bullets li {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.6;
  }

  .bullets li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-size: 0.75rem;
    top: 0.15rem;
  }

  .exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .exp-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-secondary);
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.2);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
  }

  @media (max-width: 600px) {
    .timeline-item {
      grid-template-columns: 24px 1fr;
      gap: 1rem;
    }
  }
</style>
