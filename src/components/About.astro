---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const certifications = {
  es: [
    {
      name: 'Formación en Ingeniería de Datos',
      issuer: 'Dateneo',
      year: '2025',
      tech: 'dbt · dlt · AWS',
    },
    {
      name: 'Diplomatura en Ingeniería de Datos',
      issuer: 'UTN FRRe',
      year: '2024',
      link: 'https://github.com/Valenkebat/diplomatura_DE_utn',
    },
  ],
  en: [
    {
      name: 'Data Engineering Training',
      issuer: 'Dateneo',
      year: '2025',
      tech: 'dbt · dlt · AWS',
    },
    {
      name: 'Data Engineering Diploma',
      issuer: 'UTN FRRe',
      year: '2024',
      link: 'https://github.com/Valenkebat/diplomatura_DE_utn',
    },
  ],
};

const education = {
  es: [
    {
      degree: 'Analista Programador Universitario',
      institution: 'Facultad de Informática – UNLP',
      status: 'En curso',
    },
    {
      degree: 'Licenciatura en Sociología',
      institution: 'Facultad de Humanidades – UNLP',
      status: '2014 – 2017',
    },
  ],
  en: [
    {
      degree: 'College Programmer Analyst',
      institution: 'Faculty of Computer Science – UNLP',
      status: 'In Progress',
    },
    {
      degree: "Bachelor's Degree in Sociology",
      institution: 'Faculty of Humanities – UNLP',
      status: '2014 – 2017',
    },
  ],
};

const certs = certifications[lang];
const edu = education[lang];

const hobbies = ['🍞', '🌱', '🚴', '🎺'];
const hobbyLabels = {
  es: ['Pan integral', 'Jardinería', 'Ciclismo', 'Trombón'],
  en: ['Whole grain bread', 'Gardening', 'Cycling', 'Trombone'],
};
---

<section class="about-section" id="about">
  <div class="container">
    <h2 class="section-title">{t('about.title')}</h2>

    <div class="about-grid">
      <div class="about-text">
        <p>{t('about.p1')}</p>
        <p>{t('about.p2')}</p>
        <p>{t('about.p3')}</p>

        <div class="hobbies">
          {hobbies.map((emoji, i) => (
            <div class="hobby-pill glass">
              <span class="hobby-emoji">{emoji}</span>
              <span class="hobby-label">{hobbyLabels[lang][i]}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="about-sidebar">
        <div class="sidebar-block glass">
          <h3 class="sidebar-title">
            {lang === 'es' ? 'Educación' : 'Education'}
          </h3>
          {edu.map(e => (
            <div class="edu-item">
              <p class="edu-degree">{e.degree}</p>
              <p class="edu-institution">{e.institution}</p>
              <span class="edu-status mono">{e.status}</span>
            </div>
          ))}
        </div>

        <div class="sidebar-block glass">
          <h3 class="sidebar-title">
            {lang === 'es' ? 'Cursos & Certificaciones' : 'Courses & Certifications'}
          </h3>
          {certs.map(c => (
            <div class="cert-item">
              <p class="cert-name">{c.name}</p>
              <p class="cert-issuer">{c.issuer} · <span class="mono">{c.year}</span></p>
              {c.tech && <p class="cert-tech mono">{c.tech}</p>}
              {c.link && (
                <a href={c.link} target="_blank" rel="noopener" class="cert-link">
                  GitHub ↗
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 6rem 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem;
    align-items: start;
  }

  .about-text p {
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    line-height: 1.8;
    font-size: 1rem;
  }

  .hobbies {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .hobby-pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    transition: var(--transition);
  }

  .hobby-pill:hover {
    border-color: rgba(0, 255, 204, 0.2);
    transform: translateY(-2px);
  }

  .hobby-emoji {
    font-size: 1.1rem;
  }

  .hobby-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .about-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-block {
    padding: 1.5rem;
    border-radius: var(--radius-lg);
  }

  .sidebar-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    margin-bottom: 1.25rem;
    font-weight: 700;
  }

  .edu-item {
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.25rem;
  }

  .edu-item:last-child {
    margin-bottom: 0;
    border-bottom: none;
    padding-bottom: 0;
  }

  .edu-degree {
    font-weight: 700;
    font-size: 0.9rem;
    margin-bottom: 0.2rem;
  }

  .edu-institution {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 0.35rem;
  }

  .edu-status {
    font-size: 0.75rem;
    color: var(--color-primary);
  }

  .cert-item {
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.25rem;
  }

  .cert-item:last-child {
    margin-bottom: 0;
    border-bottom: none;
    padding-bottom: 0;
  }

  .cert-name {
    font-weight: 700;
    font-size: 0.9rem;
    margin-bottom: 0.2rem;
  }

  .cert-issuer {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-bottom: 0.3rem;
  }

  .cert-tech {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .cert-link {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    margin-top: 0.3rem;
    display: inline-block;
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
