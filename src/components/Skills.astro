---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const skillGroups = [
  {
    titleKey: 'skills.orchestration',
    icon: '⚙️',
    skills: [
      { name: 'Apache Airflow', level: 90 },
      { name: 'dbt', level: 85 },
      { name: 'dlt', level: 75 },
      { name: 'Docker', level: 80 },
    ],
  },
  {
    titleKey: 'skills.cloud',
    icon: '☁️',
    skills: [
      { name: 'AWS (Redshift, S3)', level: 85 },
      { name: 'ECS / Fargate', level: 75 },
      { name: 'Node.js', level: 70 },
    ],
  },
  {
    titleKey: 'skills.programming',
    icon: '💻',
    skills: [
      { name: 'Python', level: 95 },
      { name: 'SQL', level: 90 },
      { name: 'PostgreSQL', level: 85 },
      { name: 'SQL Server', level: 80 },
      { name: 'JavaScript / TypeScript', level: 70 },
    ],
  },
];

const scraping = ['BeautifulSoup', 'Selenium', 'API Integration', 'Dynamic/JS content'];
---

<section class="skills-section" id="skills">
  <div class="container">
    <h2 class="section-title">{t('skills.title')}</h2>

    <div class="skills-grid">
      {skillGroups.map(group => (
        <div class="skill-card glass">
          <h3 class="skill-group-title">
            <span class="icon">{group.icon}</span>
            {t(group.titleKey as any)}
          </h3>
          <div class="skill-list">
            {group.skills.map(skill => (
              <div class="skill-row">
                <div class="skill-label-row">
                  <span class="skill-name">{skill.name}</span>
                  <span class="skill-pct mono">{skill.level}%</span>
                </div>
                <div class="bar-track">
                  <div class="bar-fill" style={`width: ${skill.level}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="scraping-block glass">
      <h3 class="skill-group-title"><span class="icon">🕷️</span> Web Scraping</h3>
      <div class="scraping-tags">
        {scraping.map(s => (
          <span class="scraping-tag">{s}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .skills-section {
    padding: 6rem 0;
    background: linear-gradient(180deg, transparent, rgba(19,26,40,0.4) 50%, transparent);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .skill-card, .scraping-block {
    padding: 1.75rem;
    border-radius: var(--radius-lg);
    transition: var(--transition);
  }

  .skill-card:hover, .scraping-block:hover {
    border-color: rgba(0, 255, 204, 0.15);
    transform: translateY(-3px);
  }

  .skill-group-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .icon {
    font-size: 1.2rem;
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skill-label-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.35rem;
  }

  .skill-name {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .skill-pct {
    font-size: 0.78rem;
    color: var(--color-primary);
  }

  .bar-track {
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
    border-radius: 2px;
    transition: width 1s ease-out;
  }

  .scraping-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .scraping-tag {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    background: var(--color-primary-glow);
    border: 1px solid rgba(0, 255, 204, 0.3);
    color: var(--color-primary);
    transition: var(--transition);
  }

  .scraping-tag:hover {
    background: rgba(0, 255, 204, 0.15);
  }
</style>
